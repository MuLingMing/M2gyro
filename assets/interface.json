{
    "interface_version": 2,
    "name": "M2gyro",
    "description": "这是一个使用 MaaFramework 创建的新项目，目标为二重螺旋。",
    "contact": "QQ群: 暂无",
    "license": "MIT",
    "welcome": "首次使用！欢迎使用 M2gyro!",
    "github": "https://github.com/MuLingMing/M2gyro",
    "version": "0.2.0",
    "mirrorchyan_multiplatform": false,
    "icon": "./assets/logo.ico",
    "controller": [
        {
            "name": "安卓端",
            "type": "Adb",
            "display_short_side": 720
        }
    ],
    "resource": [
        {
            "name": "安卓云游戏",
            "path": [
                "./resource/base"
            ]
        },
        {
            "name": "安卓本地游戏",
            "path": [
                "./resource/base",
                "./resource/Android"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "-u",
            "./../agent/main.py"
        ]
    },
    "import": [
        "./resource/attach/option.interface.json",
        "./resource/attach/委托.interface.json",
        "./resource/attach/夜航手册.interface.json",
        "./resource/attach/委托密函.interface.json",
        "./resource/attach/预设.interface.json",
        "./resource/attach/测试.interface.json"
    ],
    "task": [
        {
            "name": "启动游戏",
            "default_check": true,
            "entry": "启动游戏",
            "description": "必选用于启动游戏"
        }
    ]
}