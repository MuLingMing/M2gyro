{
    "interface_version": 2,
    "name": "M2gyro",
    "description": "这是一个使用 MaaFramework 创建的新项目，目标为二重螺旋。",
    "contact": "QQ群: 暂无",
    "license": "MIT",
    "welcome": "首次使用！欢迎使用 M2gyro!",
    "github": "https://github.com/MuLingMing/M2gyro",
    "version": "0.2.0",
    "mirrorchyan_multiplatform": false,
    "icon": "./assets/logo.ico",
    "controller": [
        {
            "name": "安卓端",
            "type": "Adb",
            "display_short_side": 720
        }
    ],
    "resource": [
        {
            "name": "安卓云游戏",
            "path": [
                "./resource/base"
            ]
        },
        {
            "name": "安卓本地游戏",
            "path": [
                "./resource/base",
                "./resource/Android"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "-u",
            "./../agent/main.py"
        ]
    },
    "import": [
        "./resource/attach/委托.interface.json",
        "./resource/attach/夜航手册.interface.json",
        "./resource/attach/委托密函.interface.json",
        "./resource/attach/预设.interface.json",
        "./resource/attach/测试.interface.json"
    ],
    "task": [
        {
            "name": "启动游戏",
            "default_check": true,
            "entry": "启动游戏",
            "description": "必选用于启动游戏"
        },
        {
            "name": "驱离测试",
            "entry": "驱离",
            "description": "测试用",
            "option": [
                "单次倍率",
                "超时时间",
                "倍率书副本次数"
            ]
        },
        {
            "name": "测试",
            "entry": "test",
            "description": "测试用",
            "option": [
                "单次倍率",
                "超时时间",
                "倍率书副本次数"
            ]
        }
    ],
    "option": {
        "倍率书副本次数": {
            "type": "input",
            "inputs": [
                {
                    "name": "target_count",
                    "label": "副本次数",
                    "description": "请输入副本刷取次数，默认为0，即无限循环。",
                    "default": "0",
                    "pipeline_type": "int"
                }
            ],
            "pipeline_override": {
                "委托完成次数": {
                    "attach": {
                        "target_count": "{target_count}"
                    }
                }
            }
        },
        "超时时间": {
            "type": "input",
            "inputs": [
                {
                    "name": "total_time",
                    "label": "超时时间",
                    "description": "设置局内超时时间，默认180s",
                    "default": "180",
                    "pipeline_type": "int"
                }
            ],
            "pipeline_override": {
                "挂机战斗": {
                    "attach": {
                        "total_time": "{total_time}"
                    }
                }
            }
        },
        "单次倍率": {
            "type": "select",
            "label": "单次倍率选择",
            "description": "可选无加成、绿书、蓝书、紫书、金书。",
            "cases": [
                {
                    "name": "无加成"
                },
                {
                    "name": "1倍绿书",
                    "pipeline_override": {
                        "倍率选择": {
                            "template": [
                                "委托手册/1绿书_图标.png"
                            ]
                        }
                    }
                },
                {
                    "name": "2倍蓝书",
                    "pipeline_override": {
                        "倍率选择": {
                            "template": [
                                "委托手册/2蓝书_图标.png"
                            ]
                        }
                    }
                },
                {
                    "name": "8倍蓝书",
                    "pipeline_override": {
                        "倍率选择": {
                            "template": [
                                "委托手册/8紫书_图标.png"
                            ]
                        }
                    }
                },
                {
                    "name": "20倍金书",
                    "pipeline_override": {
                        "倍率选择": {
                            "template": [
                                "委托手册/20金书_图标.png"
                            ]
                        }
                    }
                }
            ]
        },
        "波次选择": {
            "type": "select",
            "cases": [
                {
                    "name": "15波"
                },
                {
                    "name": "12波"
                }
            ]
        }
    }
}