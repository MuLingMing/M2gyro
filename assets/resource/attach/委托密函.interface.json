            "cases": [
                {
                    "name": "角色",
                    "pipeline_override": {
                        "密函副本选择": {
                            "attach": {
                                "region_0": true
                            }
                        }
                    }
                },
                {
                    "name": "武器",
                    "pipeline_override": {
                        "密函副本选择": {
                            "attach": {
                                "region_1": true
                            }
                        }
                    }
                },
                {
                    "name": "魔之楔",
                    "pipeline_override": {
                        "密函副本选择": {
                            "attach": {
                                "region_2": true
                            }
                        }
                    }
                }
            ]
        },
        "密函关卡列表选择": {
            "type": "checkbox",
            "label": "关卡选择",
