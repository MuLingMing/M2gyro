{
    "interface_version": 2,
    "name": "选项",
    "controller": [],
    "resource": [],
    "option": {
        "通用设置": {
            "type": "select",
            "default_case": "通用设置",
            "cases": [
                {
                    "name": "通用设置",
                    "option": [
                        "倍率书副本次数",
                        "倍率书副本次数播报",
                        "单次倍率",
                        "超时时间"
                    ]
                }
            ]
        },
        "超时时间": {
            "type": "input",
            "inputs": [
                {
                    "name": "total_time",
                    "label": "超时时间",
                    "description": "设置局内超时时间，默认180s",
                    "default": "180",
                    "pipeline_type": "int"
                }
            ],
            // 超时时间生效范围
            // 挂机战斗、扼守战斗、扼守战斗无复位、避险战斗无复位
            "pipeline_override": {
                "挂机战斗复位": {
                    "attach": {
                        "total_time": "{total_time}"
                    }
                },
                "挂机战斗无复位": {
                    "attach": {
                        "total_time": "{total_time}"
                    }
                }
            }
        },
        "倍率书副本次数": {
            "type": "input",
            "inputs": [
                {
                    "name": "target_count",
                    "label": "副本次数",
                    "description": "请输入副本刷取次数，默认为0，即无限循环。",
                    "default": "0",
                    "pipeline_type": "int"
                }
            ],
            "pipeline_override": {
                "委托完成次数": {
                    "attach": {
                        "target_count": "{target_count}"
                    }
                }
            }
        },
        "倍率书副本次数播报": {
            "type": "input",
            "inputs": [
                {
                    "name": "logger_count",
                    "label": "副本次数播报",
                    "description": "请输入播报间隔，默认为10，即每十次播报一次副本次数。",
                    "default": "10",
                    "pipeline_type": "int"
                }
            ],
            "pipeline_override": {
                "委托完成次数": {
                    "attach": {
                        "logger_count": "{logger_count}"
                    }
                }
            }
        },
        "单次倍率": {
            "type": "select",
            "label": "单次倍率选择",
            "description": "可选无加成、绿书、蓝书、紫书、金书。",
            "cases": [
                {
                    "name": "无加成"
                },
                {
                    "name": "1倍绿书",
                    "pipeline_override": {
                        "倍率选择": {
                            "template": [
                                "委托手册/1绿书_图标.png"
                            ]
                        }
                    }
                },
                {
                    "name": "2倍蓝书",
                    "pipeline_override": {
                        "倍率选择": {
                            "template": [
                                "委托手册/2蓝书_图标.png"
                            ]
                        }
                    }
                },
                {
                    "name": "8倍蓝书",
                    "pipeline_override": {
                        "倍率选择": {
                            "template": [
                                "委托手册/8紫书_图标.png"
                            ]
                        }
                    }
                },
                {
                    "name": "20倍金书",
                    "pipeline_override": {
                        "倍率选择": {
                            "template": [
                                "委托手册/20金书_图标.png"
                            ]
                        }
                    }
                }
            ]
        }
    }
}