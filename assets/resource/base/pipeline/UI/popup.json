{
    //记录可复用的节点
    //返回上一级、弹窗确定、弹窗取消、结束当前任务、空
    "返回上一级": {
        //识别左上角返回或弹窗红叉或弹窗取消
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    "返回键匹配识别",
                    "弹窗取消",
                    "弹窗关闭匹配识别",
                    "公告关闭"
                ]
            }
        },
        "action": "Click"
    },
    "弹窗确定": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "开始挑战",
                    "确定",
                    "开始"
                ],
                "roi": [
                    165,
                    110,
                    950,
                    480
                ]
            }
        },
        "action": "Click",
        //增加确定之后的延迟，防止页面切换过慢
        "post_delay": 1000,
        "next": [
            "空"
        ]
    },
    "弹窗取消": {
        //弹窗取消文字：放弃、取消
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "放弃",
                    "取消",
                    "我知道啦",
                    "点击空白区域关闭",
                    "空白区域"
                ]
            }
        },
        "action": "Click"
    },
    "公告关闭": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": "主页面/返回上一级/公告关闭/"
            }
        },
        "action": "Click"
    },
    "结束当前任务": {
        "action": "StopTask"
    },
    "空": {
        "pre_delay": 0,
        "pre_wait_freezes": 0,
        "post_delay": 0,
        "post_wait_freezes": 0
    },
    "游戏内": {
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    "主页面-角色面板",
                    "角色面板-历练",
                    "返回上一级",
                    "退出委托",
                    "局内放弃委托"
                ]
            }
        }
    },
    "主页面匹配识别": {
        //主页面的角色面板图标
        //判断在主页面
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": "主页面/角色面板/图标/",
                "roi": [
                    0,
                    0,
                    100,
                    75
                ]
            }
        }
    },
    "角色面板匹配识别": {
        //角色面板-历练图标
        //判断在角色面板
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    {
                        "recognition": {
                            "type": "TemplateMatch",
                            "param": {
                                "template": "主页面/角色面板/历练/图标",
                                "roi": [
                                    20,
                                    285,
                                    480,
                                    410
                                ]
                            }
                        }
                    },
                    {
                        "recognition": {
                            "type": "OCR",
                            "param": {
                                "expected": "历练",
                                "roi": [
                                    20,
                                    285,
                                    480,
                                    410
                                ]
                            }
                        }
                    }
                ]
            }
        }
    },
    "返回键匹配识别": {
        //左上角的红色返回键
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "主页面/返回上一级/返回/"
                ],
                "roi": [
                    0,
                    0,
                    180,
                    100
                ]
            }
        }
    },
    "弹窗关闭匹配识别": {
        //弹窗右上角的红叉
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "主页面/返回上一级/弹窗关闭/"
                ],
                "roi": [
                    165,
                    110,
                    950,
                    480
                ]
            }
        }
    },
    "离开副本匹配识别": {
        //副本内左上角离开副本图标
        //判断在副本内
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "副本/副本退出/离开副本/"
                ],
                "roi": [
                    0,
                    0,
                    100,
                    75
                ],
                "threshold": 0.8
            }
        }
    }
}