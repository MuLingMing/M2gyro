    "委托报酬选择": {
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "RewardSelector"
            }
        },
        "action": "Click",
        "next": [
            "弹窗确定",
            "空"
        ]
    },
    "选择密函": {
        //默认选择第一个密函
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": "委托密函/选择密函/不使用密函/"
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target": true,
                "target_offset": [
                    100,
                    0,
                    0,
                    -20
                ]
            }
        },
        "next": [
            "弹窗确定",
            "购买密函识别",
            "选择密函",
            "空"
        ]
    },
