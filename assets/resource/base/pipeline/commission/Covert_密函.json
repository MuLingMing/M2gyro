{
    //委托密函
    "委托密函": {
        //驱离、探险/无尽、扼守/无尽
        "next": [
            "密函副本选择",
            "[JumpBack]委托密函页面"
        ]
    },
    "密函副本选择": {
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "CovertStage",
                "custom_recognition_param": {
                    "region_types": [
                        "角色",
                        "武器",
                        "魔之楔"
                    ],
                    "stage_list": [
                        "探险",
                        "驱离",
                        "扼守"
                    ]
                }
            }
        },
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "IfElseAction",
                "custom_action_param": {
                    "if": {
                        "action": [
                            {
                                "action": "Click",
                                "param": {
                                    "target": true
                                }
                            }
                        ],
                        "next": [
                            "密函副本跳转"
                        ]
                    }
                }
            }
        }
    },
    "密函副本跳转": {
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "IfElseReco",
                "custom_recognition_param": {
                    "if": "密函副本选择驱离",
                    "elif": "密函副本选择探险",
                    "else": "密函副本选择扼守"
                }
            }
        },
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "IfElseAction",
                "custom_action_param": {
                    "if": "密函副本选择驱离",
                    "elif": "密函副本选择探险",
                    "else": "密函副本选择扼守"
                }
            }
        }
    },
    "密函副本选择驱离": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
