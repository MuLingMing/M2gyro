{
    "委托密函": {
        //驱离、探险/无尽、扼守/无尽
        "next": [
            "密函副本选择",
            "[JumpBack]委托密函页面"
        ],
        "on_error": []
    },
    "密函副本选择": {
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "CovertStage",
                "custom_recognition_param": {
                    "region_types": [
                        "角色",
                        "武器",
                        "魔之楔"
                    ],
                    "stage_list": [
                        "驱离",
                        "探险",
                        "扼守"
                    ]
                }
            }
        },
        "action": "Click",
        "next": [
            "密函驱离"
        ]
    },
    "委托密函页面": {
        "next": [
            "委托-委托密函",
            //主页面->历练-委托
            "[JumpBack]历练-委托",
            "[JumpBack]主页面-历练",
            "[JumpBack]角色面板-历练",
            "[JumpBack]主页面-角色面板",
            "[JumpBack]返回上一级",
            "[JumpBack]退出委托",
            "[JumpBack]局内放弃委托"
        ]
    },
    "委托报酬选择": {
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "RewardSelector"
            }
        },
        "action": "Click",
        "next": [
            "弹窗确定"
        ]
    },
    "选择密函": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": "委托密函/选择密函/不使用密函/"
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target": true,
                "target_offset": [
                    100,
                    0,
                    0,
                    -20
                ]
            }
        },
        "next": [
            "弹窗确定",
            "购买密函识别",
            "选择密函"
        ]
    },
    "购买密函识别": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "购买",
                    "前往获取"
                ],
                "roi": [
                    165,
                    110,
                    950,
                    480
                ]
            }
        },
        "next": [
            "购买密函则取消",
            "购买密函没有取消则不使用"
        ]
    },
    "购买密函则取消": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "取消"
                ],
                "roi": [
                    165,
                    110,
                    950,
                    480
                ]
            }
        },
        "action": "Click"
    },
    "购买密函没有取消则不使用": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": "委托密函/选择密函/不使用密函/"
            }
        },
        "action": "Click",
        "next": [
            "局内放弃委托",
            "[JumpBack]弹窗确定",
            "购买密函没有取消则不使用"
        ]
    },
    "无尽没有委托报酬选择则退出": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "未使用密函.{0,4}无法选择密函报酬",
                    "未使用密函",
                    "无法选择"
                ],
                "roi": [
                    165,
                    110,
                    950,
                    480
                ]
            }
        },
        "next": [
            "无尽撤离"
        ]
    },
    "密函报酬选择页面": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": "密函报酬选择"
            }
        }
    },
    "委托已更新": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": "委托已更新"
            }
        },
        "next": [
            "退出委托"
        ]
    }
}