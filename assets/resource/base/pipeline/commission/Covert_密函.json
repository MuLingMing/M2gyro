    "密函驱离副本": {
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "Countdown",
                "custom_recognition_param": {
                    "total_time": 120,
                    "entry": [
                        {
                            "name": "局内复位",
                            "run": false
                        }
                    ],
                    "Interrupt": [
                        {
                            "name": "确认选择",
                            "run": false,
                            "interval": 2
                        },
                        {
                            "name": "委托报酬选择",
                            "run": false,
                            "interval": 2
                        }
                    ],
                    "Continue": [
                        {
                            "name": "局内复位",
                            "run": 1
                        },
                        {
                            "name": "释放技能E",
