{
    //机关破解
    "机关操作": {
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    {
                        "recognition": {
                            "type": "TemplateMatch",
                            "param": {
                                "template": [
                                    "副本/机关交互/"
                                ],
                                "roi": [
                                    560,
                                    200,
                                    460,
                                    320
                                ]
                            }
                        }
                    },
                    {
                        "recognition": {
                            "type": "OCR",
                            "param": {
                                "expected": [
                                    "操作"
                                ],
                                "roi": [
                                    560,
                                    200,
                                    460,
                                    320
                                ]
                            }
                        }
                    }
                ]
            }
        },
        "action": "Click",
        "next": [
            "机关操作",
            "空"
        ]
    },
    "机关破解": {
        "recognition": {
            "type": "Custom",
            "param": {
                "custom_recognition": "IfElseReco",
                "custom_recognition_param": {
                    "if": "巧手快速破解"
                }
            }
        },
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "IfElseAction",
                "custom_action_param": {
                    "if": "巧手快速破解"
