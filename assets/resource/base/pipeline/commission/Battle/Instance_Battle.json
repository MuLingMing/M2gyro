{
    //通用副本
    "通用副本": {
        //通用副本override
        // "挂机战斗无复位": {
        //     "attach": {
        //         "Continue": [
        //             {
        //                 "name": "局内复位",
        //                 "run": 1
        //             }
        //         ]
        //     }
        // },
        "next": [
            "委托已更新",
            "[JumpBack]确认选择",
            "[JumpBack]选择密函",
            "[JumpBack]倍率选择0加成",
            "[JumpBack]委托密函进入战斗",
            "[JumpBack]委托报酬选择",
            "[JumpBack]弹窗关闭匹配识别"
        ]
    },
    "委托密函进入战斗": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "副本/副本退出/离开副本/"
                ],
                "roi": [
                    0,
                    0,
                    100,
                    75
                ]
            }
        },
        "next": [
            "退出委托仅识别",
            "[JumpBack]机关操作",
            "[JumpBack]机关破解",
            "[JumpBack]无尽行动抉择",
            "[JumpBack]挂机战斗无复位",
            "[JumpBack]委托报酬选择"
        ]
    },
    //挂机战斗复位、挂机战斗无复位
    "挂机战斗复位": {
        //基底挂机战斗流程，驱离默认
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "副本/副本退出/离开副本/"
                ],
                "roi": [
                    0,
                    0,
                    100,
                    75
                ]
            }
        },
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "Countdown",
                "custom_action_param": {
                    "total_time": 120,
                    "Interrupt": [
                        "委托报酬选择",
                        {
                            "name": "确认选择",
                            "run": false,
                            "interval": 2
                        }
                    ],
                    "Continue": [
                        "局内继续游戏",
                        {
                            "name": "局内复位",
                            "run": 1
                        },
                        {
                            "name": "释放技能E",
                            "interval": 3,
                            "delay": 2
                        },
                        {
                            "name": "释放状态Q",
                            "interval": 3,
                            "delay": 2
                        },
                        {
                            "name": "下蹲防挂机",
                            "interval": 30
                        },
                        "机关操作",
                        "机关破解"
                    ],
                    "Over": "放弃委托"
                }
            }
        }
    },
    "挂机战斗无复位": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "副本/副本退出/离开副本/"
                ],
                "roi": [
                    0,
                    0,
                    100,
                    75
                ]
            }
        },
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "Countdown",
                "custom_action_param": {
                    "total_time": 120,
                    "Interrupt": [
                        "委托报酬选择",
                        {
                            "name": "挑战更多轮次可获得",
                            "run": false,
                            "interval": 2
                        },
                        {
                            "name": "确认选择",
                            "run": false,
                            "interval": 2
                        },
                        {
                            "name": "探险扼守未抵达目的地",
                            "run": true,
                            "interval": 2,
                            "start_after": 10,
                            "max_reco": 5,
                            "record_reco": true
                        }
                    ],
                    "Continue": [
                        "局内继续游戏",
                        "弹窗取消",
                        {
                            "name": "释放技能E",
                            "interval": 3,
                            "delay": 2
                        },
                        {
                            "name": "释放状态Q",
                            "interval": 3,
                            "delay": 2
                        },
                        {
                            "name": "下蹲防挂机",
                            "interval": 30
                        },
                        "机关操作",
                        "机关破解"
                    ],
                    "Over": "放弃委托"
                }
            }
        }
    },
    "探险扼守未抵达目的地": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "调查目标",
                    "前往目标点"
                ],
                "roi": [
                    0,
                    0,
                    350,
                    500
                ]
            }
        },
        "next": [
            "局内放弃委托"
        ]
    },
    //释放技能E、释放状态Q
    "释放技能E": {
        //仅识别水母E
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "副本/角色/水母E.png"
                ]
            }
        },
        "action": "Click"
    },
    "释放状态Q": {
        //仅识别菲娜、赛琪、黎瑟Q
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "副本/角色/菲娜Q.png",
                    "副本/角色/赛琪Q.png",
                    "副本/角色/黎瑟Q.png"
                ],
                "threshold": 0.9
            }
        },
        "action": "Click"
        //仅识别一次
        // "next": [
        //     "技能Q状态",
        //     "空"
        // ]
    },
    "技能Q状态": {
        //技能Q蓝耗为0证明开着，反转结果后，点击
        "inverse": true,
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "副本/角色/持续技能蓝耗0.png"
                ],
                "roi": "释放状态Q",
                "roi_offset": [
                    -17,
                    -45,
                    50,
                    75
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target": "释放状态Q"
            }
        }
    },
    //局内复位
    "局内复位": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "副本/副本退出/离开副本/"
                ],
                "roi": [
                    0,
                    0,
                    100,
                    75
                ]
            }
        },
        "action": "Click",
        //无法点击则重来
        "next": [
            "重置角色位置确定",
            "[JumpBack]复位角色",
            "[JumpBack]设置其他",
            "[JumpBack]局内设置-复位",
            "局内复位",
            "[JumpBack]弹窗取消"
        ]
    },
    "局内设置-复位": {
        //识别局内退出后设置图标
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    {
                        "recognition": {
                            "type": "TemplateMatch",
                            "param": {
                                "template": [
                                    "副本/副本退出/复位/设置/"
                                ],
                                "roi": [
                                    710,
                                    540,
                                    570,
                                    180
                                ]
                            }
                        }
                    },
                    {
                        "recognition": {
                            "type": "OCR",
                            "param": {
                                "expected": [
                                    "设置"
                                ],
                                "roi": [
                                    710,
                                    540,
                                    570,
                                    180
                                ]
                            }
                        }
                    }
                ]
            }
        },
        "action": "Click"
    },
    "设置其他": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "副本/副本退出/复位/设置-其他/"
                ],
                "roi": [
                    0,
                    350,
                    150,
                    100
                ]
            }
        },
        "action": "Click"
    },
    "复位角色": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "复位角色"
                ]
            }
        },
        "action": "Click"
    },
    "重置角色位置确定": {
        "recognition": {
            "type": "And",
            "param": {
                "box_index": 0,
                "all_of": [
                    "弹窗确定",
                    {
                        "type": "OCR",
                        "param": {
                            "expected": [
                                "重置角色位置",
                                "重置角色",
                                "角色位置"
                            ],
                            "roi": [
                                165,
                                110,
                                950,
                                480
                            ]
                        }
                    }
                ]
            }
        },
        "action": "Click",
        "next": [
            "重置角色位置确定",
            "空"
        ],
        "on_error": [
            "弹窗取消"
        ]
    },
    //下蹲防挂机
    "下蹲防挂机": {
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "OperationRecordAction",
                "custom_action_param": {
                    "operations": [
                        {
                            "action": "crouch"
                        }
                    ]
                }
            }
        }
    }
}