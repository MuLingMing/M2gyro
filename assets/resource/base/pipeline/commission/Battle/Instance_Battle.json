{
    "释放技能E": {
        //仅识别水母E
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "副本/角色/水母E.png"
                ]
            }
        },
        "action": "Click"
    },
    "释放状态Q": {
        //仅识别菲娜、赛琪、黎瑟Q
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "副本/角色/菲娜Q.png",
                    "副本/角色/赛琪Q.png",
                    "副本/角色/黎瑟Q.png"
                ]
            }
        },
        //仅识别一次
        "next": [
            "技能Q状态",
            "空"
        ]
    },
    "技能Q状态": {
        //技能Q蓝耗为0证明开着，反转结果后，点击
        "inverse": true,
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "副本/角色/持续技能蓝耗0.png"
                ],
                "roi": "释放状态Q",
                "roi_offset": [
                    -17,
                    -45,
                    50,
                    75
                ]
            }
        },
        "action": {
            "type": "Click",
            "param": {
                "target": "释放状态Q"
            }
        }
    },
    "局内复位": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "副本/副本退出/离开副本/"
                ],
                "roi": [
                    0,
                    0,
                    100,
                    75
                ]
            }
        },
        "action": "Click",
        //无法点击则重来
        "next": [
            "离开副本匹配识别",
            "[JumpBack]弹窗取消",
            "[JumpBack]复位角色",
            "[JumpBack]设置其他",
            "[JumpBack]局内设置-复位"
        ]
    },
    "局内设置-复位": {
        //识别局内退出后设置图标
        "recognition": {
            "type": "Or",
            "param": {
                "any_of": [
                    {
                        "recognition": {
                            "type": "TemplateMatch",
                            "param": {
                                "template": [
                                    "副本/副本退出/复位/设置/"
                                ],
                                "roi": [
                                    710,
                                    540,
                                    570,
                                    180
                                ]
                            }
                        }
                    },
                    {
                        "recognition": {
                            "type": "OCR",
                            "param": {
                                "expected": [
                                    "设置"
                                ],
                                "roi": [
                                    710,
                                    540,
                                    570,
                                    180
                                ]
                            }
                        }
                    }
                ]
            }
        },
        "action": "Click"
    },
    "设置其他": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "template": [
                    "副本/副本退出/复位/设置-其他/"
                ],
                "threshold": 0.9,
                "roi": [
                    0,
                    350,
                    150,
                    100
                ]
            }
        },
        "action": "Click"
    },
    "复位角色": {
        "recognition": {
            "type": "OCR",
            "param": {
                "expected": [
                    "复位角色"
                ]
            }
        },
        "action": "Click",
        "next": [
            "弹窗确定"
        ]
    }
}