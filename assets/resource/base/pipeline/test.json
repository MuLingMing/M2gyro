{
    "test_OperationRecordAction_turn": {
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "OperationRecordAction",
                "custom_action_param": {
                    "operations": [
                        {
                            "action": "turn",
                            "params": {
                                "angle": -60
                            }
                        }
                    ]
                }
            }
        }
    },
    "test_OperationRecordAction_move": {
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "OperationRecordAction",
                "custom_action_param": {
                    "operations": [
                        {
                            "action": "move",
                            "params": {
                                "direction": "forward",
                                "duration": 6,
                                "overlays": [
                                    {
                                        "action": "move",
                                        "params": {
                                            "direction": "left",
                                            "duration": 3
                                        },
                                        "at": 2
                                    },
                                    {
                                        "action": "jump",
                                        "at": 4
                                    }
                                ]
                            }
                        },
                        {
                            "action": "move",
                            "params": {
                                "direction": "backward",
                                "duration": 6,
                                "overlays": [
                                    {
                                        "action": "move",
                                        "params": {
                                            "direction": "left",
                                            "duration": 7
                                        },
                                        "at": 2
                                    },
                                    {
                                        "action": "jump",
                                        "at": 4
                                    }
                                ]
                            }
                        }
                    ]
                }
            }
        }
    },
    "test_Count": {
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "Count",
                "custom_action_param": {
                    "count": 1,
                    "target_count": 2,
                    "logger_count": true,
                    "log_else": "else{node_name},{count}",
                    "log_next": "next{node_name},{count}"
                }
            }
        }
    }
}