    "test_OperationRecordAction_move": {
        "action": {
            "type": "Custom",
            "param": {
                "custom_action": "OperationRecordAction",
                "custom_action_param": {
                    "operations": [
                        {
                            "action": "move",
                            "params": {
                                "direction": "forward",
                                "duration": 1.5,
                                "overlays": [
                                    {
                                        "action": "jump",
                                        "at": 0.6
                                    }
                                ]
                            }
                        },
                        {
                            "action": "move",
                            "params": {
                                "direction": "right",
                                "duration": 1.5
                            }
                        },
                        {
                            "action": "move",
                            "params": {
                                "direction": "backward",
                                "duration": 2.1,
                                "overlays": [
                                    {
                                        "action": "dodge",
                                        "at": 0.6
                                    }
                                ]
                            }
                        },
                        {
                            "action": "move",
                            "params": {
                                "direction": "left",
                                "duration": 0.9
                            }
                        }
                    ]
                }
            }
        }
    },
