{
    "actions": {
        "move": {
            "description": "移动动作",
            "parameters": {
                "direction": {
                    "type": "string",
                    "required": true,
                    "options": [
                        "forward",
                        "backward",
                        "left",
                        "right"
                    ]
                },
                "duration": {
                    "type": "number",
                    "required": true,
                    "min": 0
                },
                "acceleration": {
                    "type": "boolean",
                    "required": false,
                    "default": true,
                    "description": "是否启用加速度"
                }
            }
        },
        "jump": {
            "description": "跳跃动作",
            "parameters": {}
        },
        "dodge": {
            "description": "闪避/冲刺动作",
            "parameters": {
                "direction": {
                    "type": "string",
                    "required": false,
                    "options": [
                        "forward",
                        "backward",
                        "left",
                        "right"
                    ]
                }
            }
        },
        "turn": {
            "description": "转向动作",
            "parameters": {
                "angle": {
                    "type": "number",
                    "required": true
                }
            }
        },
        "interact": {
            "description": "交互动作",
            "parameters": {
                "interaction_type": {
                    "type": "string",
                    "required": false,
                    "default": "default"
                }
            }
        },
        "spiral_leap": {
            "description": "螺旋飞跃动作",
            "parameters": {}
        },
        "charge_attack": {
            "description": "蓄力攻击动作",
            "parameters": {
                "x": {
                    "type": "number",
                    "required": false,
                    "description": "蓄力坐标X（ADB平台）"
                },
                "y": {
                    "type": "number",
                    "required": false,
                    "description": "蓄力坐标Y（ADB平台）"
                },
                "duration": {
                    "type": "number",
                    "required": true,
                    "min": 0,
                    "description": "蓄力持续时间（秒）"
                }
            }
        },
        "crouch": {
            "description": "下蹲动作",
            "parameters": {}
        },
        "wait": {
            "description": "等待动作",
            "parameters": {
                "duration": {
                    "type": "number",
                    "required": true,
                    "min": 0
                }
            }
        }
    },
