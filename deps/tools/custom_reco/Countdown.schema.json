{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "./custom_reco/Countdown.schema.json",
    "type": "object",
    "unevaluatedProperties": false,
    "properties": {
        "custom_recognition": {
            "type": "string",
            "enum": [
                "Countdown"
            ],
            "description": "识别名，必须为 Countdown"
        },
        "custom_recognition_param": {
            "$ref": "#/definitions/CountdownParam"
        }
    },
    "definitions": {
        "CountdownParam": {
            "type": "object",
            "properties": {
                "total_time": {
                    "type": "integer",
                    "default": 60,
                    "minimum": 0,
                    "description": "总倒计时时间（秒），默认60秒。total_time=0时，进入无限循环模式"
                },
                "Interrupt": {
                    "oneOf": [
                        {
                            "type": "string",
                            "description": "节点名称"
                        },
                        {
                            "type": "array",
                            "items": {
                                "oneOf": [
                                    {
                                        "type": "string",
                                        "description": "节点名称"
                                    },
                                    {
                                        "type": "object",
                                        "properties": {
                                            "name": {
                                                "type": "string",
                                                "description": "节点名称"
                                            },
                                            "run": {
                                                "oneOf": [
                                                    {
                                                        "type": "string"
                                                    },
                                                    {
                                                        "type": "boolean"
                                                    }
                                                ],
                                                "default": true,
                                                "description": "是否执行节点，默认True"
                                            },
                                            "interval": {
                                                "type": "number",
                                                "default": 2.0,
                                                "minimum": 0,
                                                "description": "识别name的间隔时间（秒），默认2秒"
                                            },
                                            "hit": {
                                                "type": "boolean",
                                                "default": true,
                                                "description": "识别detail返回值，默认True"
                                            }
                                        },
                                        "required": [
                                            "name"
                                        ]
                                    }
                                ],
                                "description": "中断节点或节点配置"
                            },
                            "description": "中断节点列表"
                        }
                    ],
                    "description": "中断节点列表，识别到该节点时，根据run配置执行对应节点并结束。节点内部逻辑为OR关系"
                },
                "Continue": {
                    "oneOf": [
                        {
                            "type": "string",
                            "description": "节点名称"
                        },
                        {
                            "type": "array",
                            "items": {
                                "oneOf": [
                                    {
                                        "type": "string",
                                        "description": "节点名称"
                                    },
                                    {
                                        "type": "object",
                                        "properties": {
                                            "name": {
                                                "type": "string",
                                                "description": "节点名称"
                                            },
                                            "run": {
                                                "oneOf": [
                                                    {
                                                        "type": "string"
                                                    },
                                                    {
                                                        "type": "boolean"
                                                    }
                                                ],
                                                "default": true,
                                                "description": "是否执行节点，默认True"
                                            },
                                            "interval": {
                                                "type": "number",
                                                "default": 2.0,
                                                "minimum": 0,
                                                "description": "识别name的间隔时间（秒），默认2秒"
                                            },
                                            "hit": {
                                                "type": "boolean",
                                                "default": true,
                                                "description": "识别detail返回值，默认True"
                                            }
                                        },
                                        "required": [
                                            "name"
                                        ]
                                    }
                                ],
                                "description": "继续节点或节点配置"
                            },
                            "description": "继续节点列表"
                        }
                    ],
                    "description": "继续节点列表，识别到该节点时，根据run配置执行对应节点并继续识别。节点内部逻辑为OR关系"
                },
                "Over": {
                    "oneOf": [
                        {
                            "type": "string",
                            "description": "节点名称"
                        },
                        {
                            "type": "array",
                            "items": {
                                "oneOf": [
                                    {
                                        "type": "string",
                                        "description": "节点名称"
                                    },
                                    {
                                        "type": "object",
                                        "properties": {
                                            "name": {
                                                "type": "string",
                                                "description": "节点名称"
                                            },
                                            "run": {
                                                "oneOf": [
                                                    {
                                                        "type": "string"
                                                    },
                                                    {
                                                        "type": "boolean"
                                                    }
                                                ],
                                                "default": true,
                                                "description": "是否执行节点，默认True"
                                            },
                                            "interval": {
                                                "type": "number",
                                                "default": 2.0,
                                                "minimum": 0,
                                                "description": "识别name的间隔时间（秒），默认2秒"
                                            },
                                            "hit": {
                                                "type": "boolean",
                                                "default": true,
                                                "description": "识别detail返回值，默认True"
                                            }
                                        },
                                        "required": [
                                            "name"
                                        ]
                                    }
                                ],
                                "description": "超时节点或节点配置"
                            },
                            "description": "超时节点列表"
                        }
                    ],
                    "description": "超时节点列表，超时时，根据run配置执行对应节点并结束。节点内部逻辑为OR关系"
                },
                "logger": {
                    "type": "boolean",
                    "default": false,
                    "description": "是否开启日志，默认False"
                }
            },
            "additionalProperties": false
        }
    }
}