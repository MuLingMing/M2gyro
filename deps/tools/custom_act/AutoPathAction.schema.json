{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "./custom_act/AutoPathAction.schema.json",
    "if": {
        "properties": {
            "custom_action": {
                "const": "AutoPathAction"
            }
        },
        "required": [
            "custom_action"
        ]
    },
    "then": {
        "properties": {
            "custom_action_param": {
                "$ref": "#/definitions/AutoPathParam",
                "description": "AutoPathAction 自动寻路动作参数（合并版）\n\n整合目标识别、移动控制和障碍物处理的全部参数\n\n示例（默认参数）：\n{}\n\n示例（优先金门蓝门，自定义摇杆）：\n{\n    \"target_types\": [\"gold_door\", \"blue_door\", \"red_sword_door\", \"red_door\"],\n    \"strategy\": \"priority\",\n    \"joystick_center\": [800, 1000],\n    \"joystick_radius\": 100\n}\n\n示例（最近距离策略，禁用视角调整）：\n{\n    \"strategy\": \"nearest\",\n    \"enable_view_adjust\": false\n}"
            }
        },
        "required": [
            "custom_action_param"
        ]
    },
    "definitions": {
        "AutoPathParam": {
            "type": "object",
            "properties": {
                "target_types": {
                    "type": "array",
                    "items": {
                        "type": "string",
                        "enum": [
                            "gold_door",
                            "blue_door",
                            "red_sword_door",
                            "red_door",
                            "gold_diamond"
                        ]
                    },
                    "default": [
                        "gold_door",
                        "blue_door",
                        "red_sword_door",
                        "red_door",
                        "gold_diamond"
                    ],
                    "description": "要识别的目标类型列表\n\n- gold_door: 金色门（高优先级）\n- blue_door: 蓝色门（高优先级）\n- red_sword_door: 红色剑形门（中优先级）\n- red_door: 红色门（中优先级）\n- gold_diamond: 金色菱形（低优先级）"
                },
                "strategy": {
                    "type": "string",
                    "enum": [
                        "priority",
                        "nearest",
                        "reverse_priority"
                    ],
                    "default": "priority",
                    "description": "目标选择策略\n\n- priority: 按优先级排序，同优先级选最近的（默认）\n- nearest: 始终选择距离最近的目标\n- reverse_priority: 反向优先级排序，同优先级选最近的"
                },
                "target_priority": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "integer",
                        "minimum": 1
                    },
                    "default": {
                        "gold_door": 1,
                        "blue_door": 1,
                        "red_sword_door": 2,
                        "red_door": 2,
                        "gold_diamond": 3
                    },
                    "description": "各目标类型的优先级数值，数值越小优先级越高。同优先级时选距离最近的目标"
                },
                "arrival_text": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "归来",
                        "进入"
                    ],
                    "description": "到达判定文字列表。当目标旁出现这些文字时判定为已到达（OR 关系）"
                },
                "arrival_distance": {
                    "type": "number",
                    "minimum": 0.5,
                    "maximum": 20,
                    "default": 3,
                    "description": "到达判定的距离阈值（米）。目标旁显示的距离数字小于此值时判定为已到达"
                },
                "distance_roi_offset": {
                    "type": "array",
                    "items": {
                        "type": "integer"
                    },
                    "minItems": 4,
                    "maxItems": 4,
                    "default": [
                        0,
                        -80,
                        200,
                        60
                    ],
                    "description": "距离数字 OCR 区域偏移 [dx, dy, w, h]。相对于目标中心的偏移量和区域大小"
                },
                "text_roi_offset": {
                    "type": "array",
                    "items": {
                        "type": "integer"
                    },
                    "minItems": 4,
                    "maxItems": 4,
                    "default": [
                        0,
                        -120,
                        300,
                        80
                    ],
                    "description": "到达文字 OCR 区域偏移 [dx, dy, w, h]。相对于目标中心的偏移量和区域大小"
                },
                "move_duration": {
                    "type": "integer",
                    "minimum": 100,
                    "maximum": 2000,
                    "default": 500,
                    "description": "单次移动操作的持续时间（毫秒）。值越大单次移动距离越远"
                },
                "view_adjust_threshold": {
                    "type": "integer",
                    "minimum": 20,
                    "maximum": 500,
                    "default": 100,
                    "description": "视角调整触发阈值（像素）。目标偏离屏幕中心超过此值时执行视角调整"
                },
                "view_adjust_ratio": {
                    "type": "number",
                    "minimum": 0.1,
                    "maximum": 1.0,
                    "default": 0.3,
                    "description": "视角调整比例。实际滑动距离 = 偏移量 × 此比例"
                },
                "view_adjust_delay": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 2,
                    "default": 0.15,
                    "description": "视角调整后的等待延迟（秒）。用于等待画面响应"
                },
                "joystick_center": {
                    "type": "array",
                    "items": {
                        "type": "integer"
                    },
                    "minItems": 2,
                    "maxItems": 2,
                    "default": [
                        760,
                        950
                    ],
                    "description": "虚拟摇杆中心坐标 [x, y]（720p 基准）"
                },
                "joystick_radius": {
                    "type": "integer",
                    "minimum": 30,
                    "maximum": 200,
                    "default": 80,
                    "description": "虚拟摇杆最大滑动半径（像素）"
                },
                "stuck_detection_frames": {
                    "type": "integer",
                    "minimum": 5,
                    "maximum": 120,
                    "default": 30,
                    "description": "卡住检测帧数。连续 N 帧目标位置几乎不变时判定为卡住"
                },
                "stuck_threshold": {
                    "type": "integer",
                    "minimum": 10,
                    "maximum": 500,
                    "default": 100,
                    "description": "卡住检测的位置变化阈值（像素）。连续帧间目标位置变化小于此值时累计卡住计数"
                },
                "stuck_retry_count": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 10,
                    "default": 3,
                    "description": "卡住后最大重试次数。超过此次数后停止重试"
                },
                "stuck_search_delay": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 2,
                    "default": 0.2,
                    "description": "卡住搜索旋转后的等待延迟（秒）。用于等待视角旋转完成"
                },
                "search_rotation_angle": {
                    "type": "integer",
                    "minimum": 10,
                    "maximum": 180,
                    "default": 45,
                    "description": "卡住时搜索旋转的角度（度）。用于改变视角寻找新路径"
                },
                "max_loop_count": {
                    "type": "integer",
                    "minimum": 1,
                    "maximum": 1000,
                    "default": 100,
                    "description": "最大循环次数。寻路循环执行的上限，达到后退出"
                },
                "loop_interval": {
                    "type": "number",
                    "minimum": 0.01,
                    "maximum": 2,
                    "default": 0.1,
                    "description": "循环间隔时间（秒）。每次识别-动作循环之间的等待时间"
                },
                "enable_view_adjust": {
                    "type": "boolean",
                    "default": true,
                    "description": "是否启用视角调整。禁用后不会自动滑动屏幕使目标居中"
                },
                "enable_stuck_detection": {
                    "type": "boolean",
                    "default": true,
                    "description": "是否启用卡住检测。禁用后不会检测和处理卡住情况"
                }
            },
            "additionalProperties": false
        }
    }
}
