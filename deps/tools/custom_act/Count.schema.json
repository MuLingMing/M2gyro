{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "./custom_act/Count.schema.json",
    "if": {
        "properties": {
            "custom_action": {
                "const": "Count"
            }
        },
        "required": [
            "custom_action"
        ]
    },
    "then": {
        "properties": {
            "custom_action_param": {
                "$ref": "#/definitions/CountParam",
                "description": "Count 参数\n\n示例：\n{\n    \"count\": 0,\n    \"target_count\": 3,\n    \"next_node\": [\"node_name\"],\n    \"else_node\": [\"node_name\"],\n    \"reset_node\": [\"node_name\"],\n    \"logger_count\": false\n}\n\n字段说明：\n- count: 当前次数，默认 0，每次执行后自动更新\n- target_count: 目标次数，默认 0，为 0 时始终执行 else_node\n- next_node: 达到目标次数后执行的节点\n- else_node: 未达到目标次数时执行的节点\n- reset_node: 将指定节点的 count 重置为 0\n- logger_count: 运行次数输出模式，默认 false。false 不输出，true 每 10 次输出一次，整数 N 每 N 次输出一次"
            }
        },
        "required": [
            "custom_action_param"
        ]
    },
    "definitions": {
        "CountParam": {
            "type": "object",
            "properties": {
                "count": {
                    "type": "integer",
                    "default": 0,
                    "minimum": 0,
                    "description": "当前次数，默认 0。每次执行后会自动更新当前节点的 count 值"
                },
                "target_count": {
                    "type": "integer",
                    "default": 0,
                    "minimum": 0,
                    "description": "目标次数，默认 0。target_count=0 时，始终执行 else_node"
                },
                "next_node": {
                    "oneOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    ],
                    "description": "达到目标次数后执行的节点。支持多个节点，按顺序执行；可以出现重复节点；可以为空\n\n支持格式：\n- 单个节点名称（字符串）：\n  \"node_name\"\n\n- 节点列表（数组）：\n  [\n    \"node_name1\",\n    \"node_name2\"\n  ]"
                },
                "else_node": {
                    "oneOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    ],
                    "description": "未达到目标次数时执行的节点。支持多个节点，按顺序执行；可以出现重复节点；可以为空\n\n支持格式：\n- 单个节点名称（字符串）：\n  \"node_name\"\n\n- 节点列表（数组）：\n  [\n    \"node_name1\",\n    \"node_name2\"\n  ]"
                },
                "reset_node": {
                    "oneOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        }
                    ],
                    "description": "将指定节点的 count 重置为 0。支持多个节点；可以为空\n\n支持格式：\n- 单个节点名称（字符串）：\n  \"node_name\"\n\n- 节点列表（数组）：\n  [\n    \"node_name1\",\n    \"node_name2\"\n  ]"
                },
                "logger_count": {
                    "oneOf": [
                        {
                            "type": "boolean"
                        },
                        {
                            "type": "integer",
                            "minimum": 1
                        }
                    ],
                    "default": false,
                    "description": "运行次数输出模式，默认 false\n\n- false: 不输出运行次数\n- true: 每 10 次输出一次（默认模式）\n- 整数 N: 每 N 次输出一次（第 1 次和第 N 次也会输出）"
                }
            },
            "additionalProperties": false
        }
    }
}